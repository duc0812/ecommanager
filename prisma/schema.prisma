generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ShopifyStore {
  id                     String        @id @default(cuid())
  shop                   String        @unique
  connectedAt            DateTime      @default(now())
  lastSyncAt             DateTime?
  currentBalance         Float?
  currentBalanceCurrency String?
  payouts                Payout[]
  bankAccounts           BankAccount[]
  orders                 Order[]
  syncSinceDate          DateTime?
  ianaTimezone           String?
  projectId              String?       @unique
  project                Project?      @relation(fields: [projectId], references: [id])
}

model AppUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Payout {
  id                     Int          @id
  storeId                String
  store                  ShopifyStore @relation(fields: [storeId], references: [id])
  status                 String
  date                   String
  currency               String
  amount                 Float
  chargesFeeAmount       Float        @default(0)
  chargesGrossAmount     Float        @default(0)
  refundsFeeAmount       Float        @default(0)
  refundsGrossAmount     Float        @default(0)
  adjustmentsFeeAmount   Float        @default(0)
  adjustmentsGrossAmount Float        @default(0)
  bankAccountShopifyId   String?
  fetchedAt              DateTime     @default(now())
  transactions           PayoutTransaction[]
}

model BankAccount {
  id            String       @id
  storeId       String
  store         ShopifyStore @relation(fields: [storeId], references: [id])
  accountNumber String
  bankName      String
  country       String
  currency      String
  status        String
  fetchedAt     DateTime     @default(now())
}

model PayoutTransaction {
  id            Int      @id
  payoutId      Int
  payout        Payout   @relation(fields: [payoutId], references: [id])
  type          String
  currency      String
  amount        Float
  fee           Float
  net           Float
  sourceId      Int
  sourceType    String
  sourceOrderId Int?
  processedAt   DateTime
  fetchedAt     DateTime @default(now())
}

model Project {
  id             String            @id @default(cuid())
  name           String
  startDate      DateTime
  description    String?
  createdAt      DateTime          @default(now())
  assignments    StaffAssignment[]
  metaAccounts   MetaAdAccount[]
  otherBills      OtherBill[]
  fulfillmentCosts FulfillmentCost[]
  archivedAt   DateTime?
  shopifyStore ShopifyStore?
  orders       Order[]
}

model MetaAdAccount {
  id          String        @id @default(cuid())
  accountId   String        @unique
  accountName String?
  accessToken String
  currency    String?
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id])
  billings    MetaBilling[]
  lastSyncAt  DateTime?
  createdAt   DateTime      @default(now())
  dailySpends DailyAdSpend[]
}

model MetaBilling {
  id              String        @id
  adAccountId     String
  adAccount       MetaAdAccount @relation(fields: [adAccountId], references: [id])
  amount          Float
  currency        String
  billingDate     String
  status          String
  chargeType      String?
  productType     String?
  paymentMethod   String?
  paymentMethodLast4 String?
  referenceNumber String?
  receiptUrl      String?
  createdAt       DateTime      @default(now())
}

model Staff {
  id          String            @id @default(cuid())
  name        String
  role        String?
  monthlyCost Float             @default(0)
  note        String?
  createdAt   DateTime          @default(now())
  assignments StaffAssignment[]
  otherBills   OtherBill[]
  fulfillmentCosts FulfillmentCost[]
}

model StaffAssignment {
  id        String    @id @default(cuid())
  staffId   String
  projectId String
  staff     Staff     @relation(fields: [staffId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())

  @@unique([staffId, projectId])
}

model ResourceProxy {
  id           String        @id @default(cuid())
  name         String
  host         String?
  port         String?
  username     String?
  password     String?
  provider     String?
  tags         String?
  purchaseDate String?
  expireDate   String?
  status       String        @default("MAINTAIN")
  note         String?
  accounts     ToolAccount[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([status])
  @@unique([host, port])
}

model ToolAccount {
  id          String         @id @default(cuid())
  email       String
  accountCode String
  accountType String
  status      String         @default("ACTIVE")
  proxyId     String?
  proxy       ResourceProxy? @relation(fields: [proxyId], references: [id])
  tags        String?
  note        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([accountType])
  @@index([status])
  @@index([proxyId])
}

model OtherBill {
  id                 String   @id @default(cuid())
  vendorName         String
  invoiceNumber      String?
  billDate           String
  dueDate            String?
  serviceStartDate   String?
  serviceEndDate     String?
  category           String
  expenseAccount     String
  description        String?
  currency           String   @default("USD")
  subtotalAmount     Float
  taxAmount          Float    @default(0)
  totalAmount        Float
  paymentStatus      String   @default("UNPAID")
  paymentDate        String?
  paymentMethod      String?
  referenceNumber    String?
  projectId          String?
  project            Project? @relation(fields: [projectId], references: [id])
  staffId            String?
  staff              Staff?   @relation(fields: [staffId], references: [id])
  allocationNote     String?
  documentUrl        String?
  documentName       String?
  documentMimeType   String?
  documentSize       Int?
  accountingBasis    String   @default("ACCRUAL")
  recognitionDate    String
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([billDate])
  @@index([recognitionDate])
  @@index([category])
  @@index([paymentStatus])
  @@index([projectId])
  @@index([staffId])
}

model FulfillmentCost {
  id                 String   @id @default(cuid())
  providerName       String
  invoiceNumber      String?
  billDate           String
  serviceStartDate   String?
  serviceEndDate     String?
  recognitionDate    String
  costType           String
  currency           String   @default("USD")
  orderCount         Int      @default(0)
  itemCount          Int      @default(0)
  productCost        Float    @default(0)
  pickPackCost       Float    @default(0)
  shippingCost       Float    @default(0)
  storageCost        Float    @default(0)
  returnCost         Float    @default(0)
  adjustmentAmount   Float    @default(0)
  taxAmount          Float    @default(0)
  totalAmount        Float
  paymentStatus      String   @default("UNPAID")
  paymentDate        String?
  paymentMethod      String?
  referenceNumber    String?
  projectId          String?
  project            Project? @relation(fields: [projectId], references: [id])
  staffId            String?
  staff              Staff?   @relation(fields: [staffId], references: [id])
  documentUrl        String?
  documentName       String?
  documentMimeType   String?
  documentSize       Int?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([billDate])
  @@index([recognitionDate])
  @@index([costType])
  @@index([paymentStatus])
  @@index([projectId])
  @@index([staffId])
}

model Supplier {
  id                    String                @id @default(cuid())
  name                  String
  code                  String                @unique
  apiType               String?
  apiKey                String?
  firstItemShipFee      Float                 @default(0)
  additionalItemShipFee Float                 @default(0)
  currency              String                @default("USD")
  preferenceRank        Int                   @default(0)
  note                  String?
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  products              SupplierProduct[]
  templates             CsvTemplate[]
  orders                Order[]
  costHistory           SupplierCostHistory[]
  zoneOverrides         SupplierZoneOverride[]
}

model SupplierProduct {
  id                  String   @id @default(cuid())
  supplierId          String
  supplier            Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  sku                 String
  productName         String?
  baseCost            Float
  currency            String   @default("USD")
  requiresDesign      Boolean  @default(false)
  updatedAt           DateTime @updatedAt
  createdAt           DateTime @default(now())
  baseSku             String?
  productType         String?
  variant1Name        String?
  variant1Value       String?
  variant2Name        String?
  variant2Value       String?
  designTemplateUrl   String?
  minProductionDays   Int?
  maxProductionDays   Int?
  shippingByRegion    String?
  textureOfMaterial   String?
  baseSupplierMappings  ProductBaseSupplierMapping[]
  baseOverrides         ProductBaseOverride[]
  variantManualMappings VariantManualMapping[]
  @@unique([supplierId, sku])
  @@index([sku])
  @@index([baseSku])
}

model SupplierCostHistory {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  sku        String
  oldCost    Float
  newCost    Float
  changedAt  DateTime @default(now())
  @@index([supplierId, sku])
}

model Order {
  id                   String      @id
  storeId              String
  store                ShopifyStore @relation(fields: [storeId], references: [id])
  projectId            String
  project              Project     @relation(fields: [projectId], references: [id])
  shopifyOrderNumber   String
  customerEmail        String?
  customerName         String?
  shippingCountry      String?
  shippingState        String?
  financialStatus      String
  fulfillmentStatus    String?
  pipelineStatus       String      @default("READY_TO_PRODUCTION")
  currency             String
  grossAmount          Float
  subtotalAmount       Float       @default(0)
  shippingAmount       Float       @default(0)
  taxAmount            Float       @default(0)
  expectedPayout       Float
  totalFees            Float       @default(0)
  refundedAmount       Float       @default(0)
  defaultSupplierId    String?
  defaultSupplier      Supplier?   @relation(fields: [defaultSupplierId], references: [id])
  exportedAt           DateTime?
  exportedToSupplierId String?
  placedAt             DateTime
  shopTimezone          String?
  fetchedAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  lines                OrderLine[]
  shippingZone         String?
  shippingName         String?
  shippingAddress1     String?
  shippingAddress2     String?
  shippingCity         String?
  shippingZip          String?
  shippingPhone        String?
  orderType            String      @default("UNKNOWN")   // "CUSTOM" | "NON_CUSTOM" | "UNKNOWN"
  trelloCardId         String?
  trelloCardUrl        String?
  designReady          Boolean     @default(false)
  designDriveLink      String?
  @@index([placedAt])
  @@index([pipelineStatus])
  @@index([defaultSupplierId])
  @@index([projectId])
  @@index([projectId, placedAt])
}

model OrderLine {
  id                      String    @id @default(cuid())
  orderId                 String
  order                   Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shopifyLineId           String
  shopifyVariantId        String?
  variantOptions          String?
  sku                     String?
  resolvedSupplierSku     String?
  variantTitle            String?
  productTitle            String
  qty                     Int
  linePosition            Int       @default(0)
  unitPrice               Float
  resolvedSupplierId      String?
  resolvedBaseCost        Float?
  costSnapshotAt          DateTime?
  resolvedShipFirst       Float?
  resolvedShipAdditional  Float?
  resolvedImportTax       Float?
  shopifyProductType      String?
  previewCdnUrl           String?
  designDriveLink         String?
  @@index([sku])
  @@index([shopifyVariantId])
}

model CsvTemplate {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name       String
  columns    String
  rowMode    String   @default("PER_LINE")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SupplierZoneOverride {
  id           String   @id @default(cuid())
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  zoneCode     String
  countryCodes String   // JSON array of ISO2 codes
  createdAt    DateTime @default(now())
  @@unique([supplierId, zoneCode])
}

model SkuDesign {
  id           String   @id @default(cuid())
  sku          String   @unique
  designReady  Boolean  @default(false)
  driveLink    String?
  trelloCardId String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
}

model ProductBase {
  id                 String   @id @default(cuid())
  name               String
  shopifyProductType String
  variantConditions  String
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  supplierMappings ProductBaseSupplierMapping[]
  overrides        ProductBaseOverride[]
  variantMappings  VariantManualMapping[]

  @@index([shopifyProductType])
}

model ProductBaseSupplierMapping {
  id                String          @id @default(cuid())
  productBaseId     String
  supplierProductId String
  preferenceRank    Int

  productBase     ProductBase     @relation(fields: [productBaseId], references: [id], onDelete: Cascade)
  supplierProduct SupplierProduct @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)

  @@unique([productBaseId, preferenceRank])
  @@index([productBaseId])
}

model ProductBaseOverride {
  id                String          @id @default(cuid())
  productBaseId     String
  supplierProductId String
  attributeCombo    String
  notes             String?

  productBase     ProductBase     @relation(fields: [productBaseId], references: [id], onDelete: Cascade)
  supplierProduct SupplierProduct @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)

  @@index([productBaseId])
}

model VariantManualMapping {
  id                  String   @id @default(cuid())
  shopifyVariantId    String   @unique
  shopifyProductTitle String
  variantTitle        String?
  supplierProductId   String
  productBaseId       String?
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  supplierProduct SupplierProduct @relation(fields: [supplierProductId], references: [id], onDelete: Cascade)
  productBase     ProductBase?    @relation(fields: [productBaseId], references: [id], onDelete: SetNull)

  @@index([shopifyVariantId])
}

model DailyAdSpend {
  id          String        @id @default(cuid())
  adAccountId String
  adAccount   MetaAdAccount @relation(fields: [adAccountId], references: [id])
  date        String        // "YYYY-MM-DD"
  spend       Float         @default(0)
  impressions Int           @default(0)
  clicks      Int           @default(0)
  currency    String        @default("USD")
  fetchedAt   DateTime      @default(now())

  @@unique([adAccountId, date])
  @@index([date])
  @@index([adAccountId])
}
